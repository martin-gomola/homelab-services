# Mattermost Configuration

# Data path - Linux: leave commented (defaults to /srv/docker)
# macOS: uncomment and set your home path
#DATA_DIR=/Users/yourusername/srv/docker

# Port and Version
MATTERMOST_PORT=8065
MATTERMOST_VERSION=11.4.1
MATTERMOST_IMAGE=mattermost/mattermost-enterprise-edition
MM_PLUGIN_UPLOADS_ENABLED=true

# Site URL (required - your public URL)
MM_SITE_URL=https://chat.example.com
# Optional explicit WebSocket URL (recommended behind reverse proxy)
MM_WEBSOCKET_URL=wss://chat.example.com
# Optional extra origins allowed for CORS/WebSocket (comma-separated)
MM_ALLOW_CORS_FROM=https://chat.example.com

# Database
MM_DB_USER=mattermost
MM_DB_PASSWORD=your-secure-password-here
MM_DB_NAME=mattermost

# Timezone
TZ=Europe/Bratislava

# SMTP (Gmail with app password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password-here
MM_SMTP_AUTH=true
MM_SMTP_SECURITY=STARTTLS
MM_FEEDBACK_EMAIL=admin@example.com
MM_REPLY_TO_EMAIL=noreply@example.com

# Agents bootstrap (used by configure-agents.sh)
AGENTS_ENABLE_OLLAMA=true
AGENTS_OLLAMA_API_URL=http://host.docker.internal:11434/v1
AGENTS_OLLAMA_API_KEY=
AGENTS_OLLAMA_MODEL=qwen2.5-coder:7b
AGENTS_OLLAMA_BOT_NAME=ai
AGENTS_OLLAMA_BOT_DISPLAY_NAME="Ollama AI"
AGENTS_OLLAMA_BOT_INSTRUCTIONS="You are a practical engineering assistant running on local Ollama."

# Optional Codex bot (OpenAI service); requires AGENTS_CODEX_API_KEY
AGENTS_ENABLE_CODEX_BOT=false
AGENTS_CODEX_PROVIDER=openai
AGENTS_CODEX_API_URL=https://api.openai.com/v1
AGENTS_CODEX_API_KEY=
AGENTS_CODEX_MODEL=gpt-5-codex
AGENTS_CODEX_BOT_NAME=codex
AGENTS_CODEX_BOT_DISPLAY_NAME=Codex
AGENTS_CODEX_BOT_INSTRUCTIONS="You are Codex, focused on code and infrastructure tasks."

# Plugin hardening / behavior
AGENTS_ALLOWED_UPSTREAM_HOSTNAMES=host.docker.internal,api.openai.com
AGENTS_ENABLE_LLM_TRACE=false
AGENTS_STREAMING_TIMEOUT_SECONDS=120
