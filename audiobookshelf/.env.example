# Audiobookshelf - Self-hosted audiobook and podcast server

# Data path - Linux: leave commented (defaults to /srv/docker)
# macOS: uncomment and set your home path
#DATA_DIR=/Users/yourusername/srv/docker

# Optional timezone override
#TZ=Europe/Bratislava

# Port
ABS_PORT=13378

# Image tag — pin to a specific version to avoid surprise upgrades on redeploy
ABS_VERSION=2.33.1

# Suggested public URL: https://ebooks.yourdomain.com

# API base URL for helper scripts
ABS_BASE_URL=http://localhost:13378

# Admin credentials for bootstrap helpers
ABS_ADMIN_USERNAME=admin
ABS_ADMIN_PASSWORD=change-me

# Email bootstrap settings for "Send to E-Reader"
ABS_EMAIL_HOST=smtp.gmail.com
ABS_EMAIL_PORT=465
ABS_EMAIL_SECURE=true
ABS_EMAIL_REJECT_UNAUTHORIZED=true
ABS_EMAIL_USERNAME=your@email.com
ABS_EMAIL_PASSWORD=change-me-app-password
ABS_EMAIL_FROM_ADDRESS=your@email.com
ABS_EMAIL_TEST_ADDRESS=your@email.com
