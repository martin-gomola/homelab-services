# Open WebUI (requires native Ollama: brew install ollama)

#HOST_DATA_DIR=/path/to/docker-data
OPENWEBUI_PORT=3040
WEBUI_NAME=Ollama WebUI
WEBUI_URL=https://ai.example.com
CORS_ALLOW_ORIGIN=https://ai.example.com;http://localhost:3040
ENABLE_WEBSOCKET_SUPPORT=true
# Generate with: openssl rand -hex 32
WEBUI_SECRET_KEY=replace_with_64_hex_chars

# Optional: Open WebUI MCP server (run locally via uv, not Docker)
# The server will expose an MCP endpoint for clients like Codex/Claude Desktop.
OPENWEBUI_MCP_OPENWEBUI_URL=http://localhost:3040
OPENWEBUI_MCP_BIND_HOST=127.0.0.1
OPENWEBUI_MCP_PORT=8001
OPENWEBUI_MCP_PATH=/mcp
OPENWEBUI_MCP_API_KEY=

# Optional: mcpo bridge (MCP -> OpenAPI) for Context7
MCPO_CONTEXT7_PORT=8011
MCPO_CONTEXT7_API_KEY=replace_with_strong_key

# Optional: Codex gateway (OpenAPI wrapper around codex exec)
CODEX_GATEWAY_PORT=8091
CODEX_GATEWAY_API_KEY=replace_with_strong_key
# Keep the same values as mattermost/.env when running both stacks together.
CODEX_CONFIG_DIR=/path/to/codex-config
CODEX_WORKSPACE_DIR=/path/to/workspace
CODEX_TIMEOUT_SECONDS=300
CODEX_MAX_TIMEOUT_SECONDS=900
CODEX_ALLOW_WRITE=false
CODEX_DEFAULT_MODEL=gpt-5-codex
CODEX_DEFAULT_REASONING_EFFORT=low
CODEX_DISABLE_CONTEXT7=true

# Optional: models that should be configured for Open WebUI native tool calling
# Comma-separated model IDs
OPENWEBUI_TOOL_MODEL_IDS=ministral-3:8b,qwen2.5-coder:7b
# Optional: subset of OPENWEBUI_TOOL_MODEL_IDS that should use non-native tool calling
OPENWEBUI_TOOL_MODEL_NON_NATIVE_IDS=qwen2.5-coder:7b
# Optional: auto-upsert slash prompt /codex (command is stored without leading slash)
OPENWEBUI_CODEX_SLASH_ENABLE=true
OPENWEBUI_CODEX_SLASH_COMMAND=codex
OPENWEBUI_CODEX_SLASH_NAME=Codex Gateway Shortcut
OPENWEBUI_CODEX_SLASH_CONTENT=Use Codex Gateway tool delegate_delegate_post to complete this task: 

# Optional container memory caps (Docker Compose)
OPENWEBUI_MEM_LIMIT=2g
OPENWEBUI_MEM_RESERVATION=768m
CODEX_GATEWAY_MEM_LIMIT=512m
CODEX_GATEWAY_MEM_RESERVATION=128m
