# Open WebUI (requires native Ollama: brew install ollama)

#DATA_DIR=/Users/yourusername/srv/docker
OPENWEBUI_PORT=3040
WEBUI_NAME=Ollama WebUI
WEBUI_URL=https://lama.home
CORS_ALLOW_ORIGIN=https://lama.home;http://localhost:3040
ENABLE_WEBSOCKET_SUPPORT=true
# Generate with: openssl rand -hex 32
WEBUI_SECRET_KEY=replace_with_64_hex_chars

# Optional: Open WebUI MCP server (run locally via uv, not Docker)
# The server will expose an MCP endpoint for clients like Codex/Claude Desktop.
OPENWEBUI_MCP_OPENWEBUI_URL=http://localhost:3040
OPENWEBUI_MCP_BIND_HOST=127.0.0.1
OPENWEBUI_MCP_PORT=8001
OPENWEBUI_MCP_PATH=/mcp
OPENWEBUI_MCP_API_KEY=

# Optional: mcpo bridge (MCP -> OpenAPI) for Context7
MCPO_CONTEXT7_PORT=8011
MCPO_CONTEXT7_API_KEY=replace_with_strong_key

# Optional: Codex gateway (OpenAPI wrapper around codex exec)
CODEX_GATEWAY_PORT=8091
CODEX_GATEWAY_API_KEY=replace_with_strong_key
CODEX_CONFIG_DIR=/Users/yourusername/.codex
CODEX_WORKSPACE_DIR=/Users/yourusername/dev/homelab-services
CODEX_TIMEOUT_SECONDS=300
CODEX_MAX_TIMEOUT_SECONDS=900
CODEX_ALLOW_WRITE=false
CODEX_DEFAULT_MODEL=
