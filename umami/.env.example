# Umami - Lightweight privacy-focused analytics

# Data path - Linux: leave commented (defaults to /srv/docker)
# macOS: uncomment and set your home path
#DATA_DIR=/Users/yourusername/srv/docker

# Port
UMAMI_PORT=3025

# Version (postgresql-latest for PostgreSQL backend)
UMAMI_VERSION=postgresql-latest

# App secret (generate: openssl rand -base64 32)
UMAMI_APP_SECRET=change-me-generate-with-openssl-rand-base64-32

# Database
UMAMI_DB_NAME=umami
UMAMI_DB_USER=umami
UMAMI_DB_PASSWORD=your-secure-password-here

# Default login after first start: admin / umami
