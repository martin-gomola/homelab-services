# Home Assistant + Zigbee2MQTT Stack
# Copy to .env and update the values you actually use

# === General ===
TZ=UTC
DATA_DIR=/srv/docker

# === Ports ===
HA_PORT=8123
MQTT_PORT=1883
Z2M_PORT=8099

# === MQTT Credentials ===
# Used by Mosquitto, Zigbee2MQTT, and Home Assistant
MQTT_USER=mqtt
MQTT_PASSWORD=CHANGE_ME_generate_with_openssl_rand_base64_32

# === SONOFF Dongle Max Connection ===
# Recommended for Docker: use network mode
# On macOS, network mode is strongly recommended

# USB mode: device path
ZIGBEE_DEVICE=/dev/ttyACM0

# Network mode: IP of your SONOFF Dongle Max
SONOFF_DONGLE_IP=192.168.1.100
SONOFF_DONGLE_PORT=6638

# === Connection Mode ===
# Use "network" for the easiest Docker setup
ZIGBEE_CONNECTION_MODE=network

# === Home Assistant URL ===
# External URL for Home Assistant
HA_URL=https://home.domain.com

# === Codex MCP Auth ===
# Optional: long-lived access token for Codex/Home Assistant MCP
# Keep this only in your local .env, never in git
HOME_ASSISTANT_ACCESS_TOKEN=

# === macOS Development ===
# Example local data path:
# DATA_DIR=$HOME/srv/docker
