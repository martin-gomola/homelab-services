# Home Assistant + Zigbee2MQTT Stack
# Copy to .env and configure: cp .env.example .env

# === General ===
TZ=UTC
DATA_DIR=/srv/docker

# === Ports ===
HA_PORT=8123
MQTT_PORT=1883
Z2M_PORT=8099

# === MQTT Credentials ===
# Used by Mosquitto, Zigbee2MQTT, and Home Assistant
MQTT_USER=mqtt
MQTT_PASSWORD=CHANGE_ME_generate_with_openssl_rand_base64_32

# === SONOFF Dongle Max Connection ===
# USB mode: device path (check with: ls -la /dev/ttyACM* /dev/ttyUSB*)
ZIGBEE_DEVICE=/dev/ttyACM0

# Network mode (Ethernet/Wi-Fi): IP of your SONOFF Dongle Max
# Find it in your router's DHCP table or via the SONOFF app
SONOFF_DONGLE_IP=192.168.1.100
SONOFF_DONGLE_PORT=6638

# === Connection Mode ===
# Set to "usb" or "network" — affects which Z2M adapter config is used
# See README.md for setup instructions per mode
ZIGBEE_CONNECTION_MODE=network

# === macOS Development ===
# Uncomment for local development:
# DATA_DIR=$HOME/srv/docker
